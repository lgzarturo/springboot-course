root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{kt,kts}]
indent_size = 4
continuation_indent_size = 4
insert_final_newline = true
charset = utf-8
end_of_line = lf
max_line_length = 120
